# Google Gemini API Key (Required for text embeddings and chat Q&A pipeline)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# PostgreSQL connection string (Used for local development outside Docker)
# For docker-compose, this is overridden automatically to point to the db container
DATABASE_URL=postgres://postgres:postgres@localhost:5432/document_qa

# JSON Web Token Secret (Used for signing/verifying session cookies)
JWT_SECRET=cohere-enterprise-qa-secret-key-change-me
