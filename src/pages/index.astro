---
import Layout from '../layouts/Layout.astro';
import { getUserFromCookies } from '../lib/auth';

const user = getUserFromCookies(Astro.cookies);
---

<Layout title="Paper Mind - Chat with your Documents" hideDotGrid={true}>
  <div class="relative w-full overflow-hidden min-h-[85vh] flex flex-col items-center justify-center">
    
    <!-- Colorful Mesh Gradient Background -->
    <div class="absolute inset-0 z-0 vercel-mesh-bg opacity-[0.25]"></div>
    <div class="absolute inset-0 z-0 bg-gradient-to-b from-transparent via-canvas-soft/80 to-canvas-soft"></div>

    <div class="relative z-10 w-full max-w-[1000px] mx-auto px-6 text-center mt-12 mb-24">
      
      <!-- Announcement Banner -->
      <a href="/register" class="inline-flex items-center gap-2 bg-canvas border border-hairline rounded-full px-4 py-1.5 mb-8 shadow-sm hover:border-hairline-strong transition-all hover:scale-105">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-violet"></span>
        </span>
        <span class="text-sm font-medium text-body">New: Smart Document Q&A is now live</span>
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-4 h-4 text-mute"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>

      <!-- Headline -->
      <h1 class="font-display text-[56px] sm:text-[72px] leading-[1.05] tracking-tight-display text-ink mb-6 max-w-4xl mx-auto">
        Chat with your documents, <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-gradient-develop-start via-gradient-preview-start to-gradient-ship-start">instantly.</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-body mb-10 max-w-2xl mx-auto leading-relaxed">
        Upload your PDFs, manuals, and reports. Our AI instantly reads and understands them, allowing you to ask questions and get accurate answers with cited sources.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        {user ? (
          <a href="/dashboard" class="btn-primary">Go to Dashboard</a>
        ) : (
          <>
            <a href="/register" class="btn-primary">Get Started for Free</a>
            <a href="/login" class="btn-secondary">Log In</a>
          </>
        )}
      </div>
    </div>

    <!-- Features Section -->
    <div class="relative z-10 w-full max-w-[1200px] mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6 pb-24">
      <div class="card-marketing transition-all">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan/20 to-blue-500/20 border border-cyan/30 flex items-center justify-center mb-6 shadow-inner">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6 text-cyan"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
        </div>
        <h3 class="font-display text-xl font-semibold mb-3 text-ink">1. Upload Documents</h3>
        <p class="text-body text-sm leading-relaxed">Simply drag and drop your PDF files into your secure workspace. We securely process and organize your files into an intelligent library.</p>
      </div>

      <div class="card-marketing transition-all">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet/20 to-fuchsia-500/20 border border-violet/30 flex items-center justify-center mb-6 shadow-inner">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6 text-violet"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="font-display text-xl font-semibold mb-3 text-ink">2. AI Processing</h3>
        <p class="text-body text-sm leading-relaxed">Our advanced AI reads every page, extracting key information and context so it's ready to answer your questions in seconds.</p>
      </div>

      <div class="card-marketing transition-all">
        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500/20 to-orange-500/20 border border-amber-500/30 flex items-center justify-center mb-6 shadow-inner">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6 text-warning-deep"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        </div>
        <h3 class="font-display text-xl font-semibold mb-3 text-ink">3. Ask Questions</h3>
        <p class="text-body text-sm leading-relaxed">Chat with your documents like you're talking to a human expert. Get precise answers backed by exact page citations and excerpts.</p>
      </div>
    </div>
  </div>
</Layout>
