---
import Layout from '../layouts/Layout.astro';
import { initDb, sql } from '../lib/db';
import { getUserFromCookies } from '../lib/auth';

// 1. Authenticate user
const user = getUserFromCookies(Astro.cookies);
if (!user) {
  return Astro.redirect('/login');
}

// 2. Fetch context details if query parameters are present
const contextType = Astro.url.searchParams.get('type') || 'all'; // 'all', 'folder', 'document'
const contextId = Astro.url.searchParams.get('id') || '';

let contextName = 'Entire Library';

try {
  await initDb();

  if (contextType === 'folder' && contextId) {
    const folder = await sql`SELECT name FROM folders WHERE id = ${contextId} AND user_id = ${user.userId}`;
    if (folder.length > 0) {
      contextName = `Folder: ${folder[0].name}`;
    }
  } else if (contextType === 'document' && contextId) {
    const doc = await sql`SELECT name FROM documents WHERE id = ${contextId} AND user_id = ${user.userId}`;
    if (doc.length > 0) {
      contextName = `Doc: ${doc[0].name}`;
    }
  }
} catch (error) {
  console.error('Error fetching context details in chat page:', error);
}
---

<Layout title="Chat Console — Paper Mind">
  <div class="flex-grow flex h-[calc(100vh-140px)] overflow-hidden bg-canvas border-t border-hairline mt-4 rounded-t-xl shadow-[var(--shadow-level-3)] max-w-[1400px] w-full mx-auto">
    <!-- Sidebar: Chat Sessions History -->
    <aside class="w-80 bg-canvas-soft border-r border-hairline flex flex-col hidden md:flex flex-shrink-0">
      <div class="p-4 border-b border-hairline flex items-center justify-between">
        <span class="text-xs font-mono uppercase tracking-wider text-mute font-medium">Conversations</span>
        <button 
          id="newChatBtn"
          class="btn-secondary-sm"
        >
          New Chat
        </button>
      </div>
      
      <!-- Conversations List -->
      <div id="conversationsList" class="flex-grow overflow-y-auto p-3 space-y-1">
        <div class="text-center py-8 text-xs text-mute italic">Loading sessions...</div>
      </div>
    </aside>

    <!-- Main Chat Console Area -->
    <section class="flex-grow flex flex-col bg-canvas relative">
      <!-- Chat Context Status Header -->
      <div class="border-b border-hairline py-3 px-6 flex items-center justify-between bg-canvas">
        <div class="flex items-center gap-3">
          <span class="inline-block w-2.5 h-2.5 rounded-full bg-success"></span>
          <div>
            <span class="text-[10px] font-mono text-mute uppercase tracking-wider block">ACTIVE PIPELINE</span>
            <span class="font-semibold text-ink text-sm" id="activePipelineText">{contextName}</span>
          </div>
        </div>
        
        <div class="text-xs font-mono text-mute uppercase">
          <span id="citationCountText" class="bg-canvas-soft py-1 px-2.5 rounded-full border border-hairline">0 Citations Loaded</span>
        </div>
      </div>

      <!-- Scrollable Message History Pane -->
      <div id="chatMessages" class="flex-grow overflow-y-auto p-6 sm:p-12 space-y-8 bg-canvas">
        <!-- Default State Greeting -->
        <div class="max-w-2xl mx-auto text-center py-12 space-y-4" id="emptyStateGreeting">
          <span class="font-mono text-[12px] uppercase text-mute tracking-wider font-semibold">Ready to Query</span>
          <h2 class="text-3xl font-display font-semibold text-ink tracking-tight-lg">Ask your document network</h2>
          <p class="text-sm text-body max-w-md mx-auto">
            Input a natural language query below. The Gemini model will retrieve relevant context segments from your indexed PDF network and compose a response with verbatim sources.
          </p>
          <div class="pt-4 flex flex-wrap justify-center gap-2 max-w-md mx-auto text-xs">
            <button class="suggested-query py-2 px-3 border border-hairline rounded-md hover:bg-canvas-soft transition-colors font-medium text-ink shadow-[var(--shadow-level-1)]">
              "Summarize the main points of this document"
            </button>
            <button class="suggested-query py-2 px-3 border border-hairline rounded-md hover:bg-canvas-soft transition-colors font-medium text-ink shadow-[var(--shadow-level-1)]">
              "What are the key deadlines or dates?"
            </button>
          </div>
        </div>
      </div>

      <!-- Suggestion/Typing Loading Indicator -->
      <div id="typingIndicator" class="hidden px-6 sm:px-12 py-3 text-xs font-mono text-mute flex items-center justify-between bg-canvas border-t border-hairline">
        <div class="flex items-center gap-3">
          <span class="inline-block w-2 h-2 rounded-full bg-primary animate-ping"></span>
          <span id="typingIndicatorText">Retrieving knowledge chunks and calling LLM...</span>
        </div>
        <!-- Stop Generating Button -->
        <button id="stopBtn" class="btn-secondary-sm text-error hover:text-error-deep border-error-soft hover:bg-error-soft/50">
          Stop Generating
        </button>
      </div>

      <!-- Prompt Input Panel -->
      <div class="p-4 sm:p-6 bg-canvas">
        <div class="max-w-4xl mx-auto relative rounded-xl border border-hairline shadow-[var(--shadow-level-2)] focus-within:ring-2 focus-within:ring-primary focus-within:border-primary transition-all">
          <form id="chatForm" class="relative">
            <textarea
              id="chatInput"
              placeholder="Ask a question about the document context..."
              rows="1"
              class="w-full pl-4 pr-24 py-4 rounded-xl bg-transparent focus:outline-none text-sm resize-none min-h-[56px] text-ink"
              required
            ></textarea>
            
            <button
              type="submit"
              id="sendBtn"
              class="absolute right-4 bottom-3 w-8 h-8 rounded-md bg-ink text-canvas flex items-center justify-center transition-all shadow-md overflow-hidden group disabled:opacity-80 disabled:cursor-not-allowed"
            >
              <div id="sendBtnFill" class="absolute left-0 top-0 bottom-0 bg-primary w-0 transition-all duration-300 ease-out z-0"></div>
              <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
              <svg id="sendIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative z-10"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              <svg id="loadingIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 hidden animate-spin"><line x1="12" y1="2" x2="12" y2="6"></line><line x1="12" y1="18" x2="12" y2="22"></line><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line><line x1="2" y1="12" x2="6" y2="12"></line><line x1="18" y1="12" x2="22" y2="12"></line><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line></svg>
            </button>
          </form>
        </div>
        <div class="max-w-4xl mx-auto flex items-center justify-between mt-2 px-1 text-[10px] font-mono text-mute">
          <span>Press Enter to send, Shift+Enter for newline</span>
          <span>Context: <span class="text-ink font-semibold">{contextName}</span></span>
        </div>
      </div>
    </section>

    <!-- Side Panel: Verbatim Source Citations Drawer -->
    <aside id="citationsDrawer" class="w-80 bg-canvas-soft border-l border-hairline flex flex-col hidden flex-shrink-0 shadow-[-4px_0_24px_rgba(0,0,0,0.02)] z-10">
      <div class="p-4 border-b border-hairline flex items-center justify-between">
        <span class="text-xs font-mono uppercase tracking-wider text-mute font-semibold">Source Citations</span>
        <button id="closeDrawerBtn" class="text-mute hover:text-ink font-mono text-xs cursor-pointer">Close ✕</button>
      </div>
      <div id="citationsList" class="flex-grow overflow-y-auto p-4 space-y-4">
        <div class="text-center py-12 text-xs text-mute italic">Click on a bracketed citation [n] in the message history to view verbatim text excerpts and page sources here.</div>
      </div>
    </aside>
  </div>

  <div id="chat-page-data" data-type={contextType} data-id={contextId} data-name={contextName} class="hidden"></div>
  <script>
    document.addEventListener('astro:page-load', () => {
      const chatDataEl = document.getElementById('chat-page-data');
      if (!chatDataEl) return;
      
      const initialContextType = chatDataEl.dataset.type;
      const initialContextId = chatDataEl.dataset.id;
      const initialContextName = chatDataEl.dataset.name;

      // Retrieve server-injected state variables
      let currentContextType = initialContextType;
      let currentContextId = initialContextId;
      let currentContextName = initialContextName;

      // Client state
      let activeConversationId = null;
      let activeCitations = [];
      let currentAbortController = null; // Used to abort fetch requests

    // DOM Nodes
    const conversationsList = document.getElementById('conversationsList');
    const newChatBtn = document.getElementById('newChatBtn');
    const chatMessages = document.getElementById('chatMessages');
    const chatForm = document.getElementById('chatForm');
    const chatInput = document.getElementById('chatInput');
    const typingIndicator = document.getElementById('typingIndicator');
    const typingIndicatorText = document.getElementById('typingIndicatorText');
    const emptyStateGreeting = document.getElementById('emptyStateGreeting');
    const citationsDrawer = document.getElementById('citationsDrawer');
    const citationsList = document.getElementById('citationsList');
    const closeDrawerBtn = document.getElementById('closeDrawerBtn');
    const citationCountText = document.getElementById('citationCountText');
    const activePipelineText = document.getElementById('activePipelineText');
    const stopBtn = document.getElementById('stopBtn');

    // 1. Fetch User Sessions (Chat History)
    async function loadSessions() {
      try {
        const response = await fetch('/api/chat/history');
        if (response.ok) {
          const sessions = await response.json();
          renderSessions(sessions);
        }
      } catch (error) {
        console.error('Error loading chat history:', error);
      }
    }

    function renderSessions(sessions) {
      if (!conversationsList) return;
      if (sessions.length === 0) {
        conversationsList.innerHTML = '<div class="text-center py-8 text-xs text-mute italic">No chat history.</div>';
        return;
      }

      conversationsList.innerHTML = sessions.map(session => {
        const isActive = session.id === activeConversationId;
        const icon = session.document_id 
          ? `<svg class="w-3.5 h-3.5 text-mute flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>`
          : session.folder_id
            ? `<svg class="w-3.5 h-3.5 text-mute flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>`
            : `<svg class="w-3.5 h-3.5 text-mute flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>`;

        return `
          <div 
            class="session-row flex items-center justify-between py-2 px-3 rounded-md hover:bg-canvas transition-colors cursor-pointer text-xs group ${
              isActive ? 'bg-canvas font-medium shadow-[var(--shadow-level-1)]' : ''
            }" 
            data-session-id="${session.id}"
            data-session-type="${session.document_id ? 'document' : session.folder_id ? 'folder' : 'all'}"
            data-session-target-id="${session.document_id || session.folder_id || ''}"
            data-session-title="${session.title}"
          >
            <span class="flex items-center gap-2 truncate pr-2">
              ${icon}
              <span class="truncate text-ink">${session.title}</span>
            </span>
            <button 
              class="delete-session-btn text-[10px] uppercase font-mono text-mute hover:text-error opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0"
              data-id="${session.id}"
            >
              ✕
            </button>
          </div>
        `;
      }).join('');

      // Add session click handlers
      document.querySelectorAll('.session-row').forEach(row => {
        row.addEventListener('click', (e) => {
          const el = e.currentTarget;
          const sessionId = el.dataset.sessionId;
          const sessionTitle = el.dataset.sessionTitle;
          const sessionType = el.dataset.sessionType;
          const targetId = el.dataset.sessionTargetId;

          loadActiveSession(sessionId, sessionTitle, sessionType, targetId);
        });
      });

      // Delete session click handler
      document.querySelectorAll('.delete-session-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const id = e.currentTarget.dataset.id;
          if (!confirm('Are you sure you want to delete this chat session history?')) {
            return;
          }
          
          try {
            const response = await fetch(`/api/chat/history?id=${id}`, { method: 'DELETE' });
            if (response.ok) {
              window.showToast('Session deleted', 'success');
              if (activeConversationId === id) {
                resetChatConsole();
              }
              loadSessions();
            } else {
              window.showToast('Failed to delete session', 'error');
            }
          } catch (err) {
            console.error(err);
            window.showToast('Network error', 'error');
          }
        });
      });
    }

    // 2. Load Active Session Messages
    async function loadActiveSession(sessionId, title, type, targetId) {
      // Abort any ongoing request before switching
      if (currentAbortController) {
        currentAbortController.abort();
        currentAbortController = null;
        if (typingIndicator) typingIndicator.classList.add('hidden');
      }

      activeConversationId = sessionId;
      currentContextType = type;
      currentContextId = targetId;

      // Update pipeline status header text
      if (activePipelineText) {
        if (type === 'document') {
          activePipelineText.textContent = `Doc (History): ${title}`;
        } else if (type === 'folder') {
          activePipelineText.textContent = `Folder (History): ${title}`;
        } else {
          activePipelineText.textContent = `Entire Library`;
        }
      }

      // Re-render sidebar to highlight active row
      loadSessions();

      if (emptyStateGreeting) emptyStateGreeting.classList.add('hidden');
      if (chatMessages) chatMessages.innerHTML = '<div class="text-center py-12 text-xs text-mute italic">Retrieving conversations...</div>';

      try {
        const response = await fetch(`/api/chat/history?conversation_id=${sessionId}`);
        if (response.ok) {
          const data = await response.json();
          renderMessages(data.messages);
          activeCitations = data.allCitations || [];
          if (citationCountText) {
            citationCountText.textContent = `${activeCitations.length} Citations Loaded`;
          }
        }
      } catch (error) {
        console.error('Error fetching session messages:', error);
      }
    }

    // Render messages array
    function renderMessages(messages) {
      if (!chatMessages) return;
      if (messages.length === 0) {
        chatMessages.innerHTML = '<div class="text-center py-8 text-xs text-mute italic">Empty conversation. Type a query below to start.</div>';
        return;
      }

      chatMessages.innerHTML = messages.map(msg => {
        const isUser = msg.role === 'user';
        
        if (isUser) {
          return `
            <div class="flex items-start justify-end max-w-3xl ml-auto gap-4">
              <div class="bg-canvas-soft py-3 px-5 rounded-2xl border border-hairline text-sm text-ink max-w-[85%] shadow-sm">
                <p class="whitespace-pre-wrap leading-relaxed">${escapeHtml(msg.content)}</p>
              </div>
            </div>
          `;
        } else {
          // Render model response with bracketed citation links
          const formattedContent = formatResponseWithCitations(msg.content);
          return `
            <div class="flex items-start max-w-3xl gap-4">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet to-fuchsia-500 text-canvas flex items-center justify-center font-semibold text-[10px] flex-shrink-0 shadow-sm font-mono border border-violet/50">AI</div>
              <div class="py-1 px-1 bg-canvas text-sm text-ink flex-grow">
                <div class="prose leading-relaxed font-normal whitespace-pre-wrap">${formattedContent}</div>
              </div>
            </div>
          `;
        }
      }).join('');

      // Scroll to bottom
      chatMessages.scrollTop = chatMessages.scrollHeight;

      // Add click listeners to citations [n]
      document.querySelectorAll('.citation-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const idx = parseInt(e.currentTarget.dataset.index, 10);
          showCitationDetails(idx);
        });
      });
    }

    // Helper to format citation numbers as clickable links
    function formatResponseWithCitations(text) {
      // Escape HTML first
      let escaped = escapeHtml(text);
      // Replace [n] with clickable links
      return escaped.replace(/\[(\d+)\]/g, (match, p1) => {
        const index = parseInt(p1, 10) - 1;
        return `<a href="#" class="citation-link inline-block align-super text-[10px] font-bold bg-canvas-soft border border-hairline-strong text-ink px-1 rounded-sm mx-0.5 hover:bg-primary hover:text-canvas hover:border-primary transition-colors" data-index="${index}">[${p1}]</a>`;
      });
    }

    function escapeHtml(text) {
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    // Click citation details
    function showCitationDetails(index) {
      if (!citationsDrawer || !citationsList) return;

      // Open drawer
      citationsDrawer.classList.remove('hidden');

      if (index >= 0 && index < activeCitations.length) {
        const citation = activeCitations[index];
        citationsList.innerHTML = `
          <div class="p-4 bg-canvas border border-hairline rounded-md space-y-3 shadow-[var(--shadow-level-2)]">
            <div class="flex items-center justify-between border-b border-hairline pb-2">
              <span class="text-[10px] font-mono text-ink uppercase font-bold tracking-wider">Citation [${index + 1}]</span>
              <span class="text-[10px] font-mono text-mute bg-canvas-soft px-2 py-0.5 rounded-sm border border-hairline">Page ${citation.page}</span>
            </div>
            <div>
              <span class="block text-[10px] font-mono text-mute uppercase tracking-wider mb-1">Source Document</span>
              <span class="text-xs font-semibold text-ink break-words block">${citation.docName}</span>
            </div>
            <div class="pt-2 border-t border-hairline">
              <span class="block text-[10px] font-mono text-mute uppercase tracking-wider mb-2">Verbatim Text Excerpt</span>
              <blockquote class="text-xs text-body italic bg-canvas-soft p-3 rounded-md border-l-2 border-primary leading-relaxed whitespace-pre-wrap break-words">${escapeHtml(citation.snippet)}</blockquote>
            </div>
          </div>
        `;
      } else {
        citationsList.innerHTML = '<div class="text-center py-12 text-xs text-mute italic">Citation index not found in current loaded context pool.</div>';
      }
    }

    // Reset Console
    function resetChatConsole() {
      if (currentAbortController) {
        currentAbortController.abort();
        currentAbortController = null;
      }
      activeConversationId = null;
      activeCitations = [];
      if (emptyStateGreeting) emptyStateGreeting.classList.remove('hidden');
      if (chatMessages) chatMessages.innerHTML = '';
      if (citationsDrawer) citationsDrawer.classList.add('hidden');
      if (citationCountText) citationCountText.textContent = '0 Citations Loaded';
      if (activePipelineText) activePipelineText.textContent = currentContextName;
      if (typingIndicator) typingIndicator.classList.add('hidden');
    }

    // New Chat Click
    if (newChatBtn) {
      newChatBtn.addEventListener('click', () => {
        resetChatConsole();
      });
    }

    // Close Drawer
    if (closeDrawerBtn && citationsDrawer) {
      closeDrawerBtn.addEventListener('click', () => {
        citationsDrawer.classList.add('hidden');
      });
    }

    // Abort Fetch Request
    if (stopBtn) {
      stopBtn.addEventListener('click', () => {
        if (currentAbortController) {
          currentAbortController.abort();
          currentAbortController = null;
          if (typingIndicator) typingIndicator.classList.add('hidden');
          
          // Append aborted message
          const abortMsgHtml = `
            <div class="flex items-start max-w-3xl gap-4">
              <div class="w-8 h-8 rounded-full bg-primary text-canvas flex items-center justify-center font-semibold text-[10px] flex-shrink-0 shadow-sm font-mono border border-primary">AI</div>
              <div class="py-1 px-1 bg-canvas text-sm text-mute flex-grow">
                <div class="prose leading-relaxed font-normal whitespace-pre-wrap italic">Generation stopped by user.</div>
              </div>
            </div>
          `;
          chatMessages.insertAdjacentHTML('beforeend', abortMsgHtml);
          chatMessages.scrollTop = chatMessages.scrollHeight;
        }
      });
    }

    // 3. Form Submit Question
    if (chatForm && chatInput) {
      chatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const query = chatInput.value.trim();
        if (!query) return;

        // Clear input field
        chatInput.value = '';
        chatInput.style.height = 'auto';

        // Hide greeting
        if (emptyStateGreeting) emptyStateGreeting.classList.add('hidden');

        // Append user query to UI instantly
        const userMsgHtml = `
          <div class="flex items-start justify-end max-w-3xl ml-auto gap-4">
            <div class="bg-canvas-soft py-3 px-5 rounded-2xl border border-hairline text-sm text-ink max-w-[85%] shadow-sm">
              <p class="whitespace-pre-wrap leading-relaxed">${escapeHtml(query)}</p>
            </div>
          </div>
        `;
        chatMessages.insertAdjacentHTML('beforeend', userMsgHtml);
        chatMessages.scrollTop = chatMessages.scrollHeight;

        // Disable input and button
        chatInput.disabled = true;
        const sendBtn = document.getElementById('sendBtn');
        const sendBtnFill = document.getElementById('sendBtnFill');
        const sendIcon = document.getElementById('sendIcon');
        const loadingIcon = document.getElementById('loadingIcon');
        
        if (sendBtn && sendBtnFill) {
          sendBtn.setAttribute('disabled', 'true');
          // Fill animation
          sendBtnFill.style.width = '100%';
          await new Promise(resolve => setTimeout(resolve, 300));
        }

        if (sendIcon && loadingIcon) {
          sendIcon.classList.add('hidden');
          loadingIcon.classList.remove('hidden');
        }

        // Show typing indicator
        if (typingIndicator) typingIndicator.classList.remove('hidden');

        // Set up AbortController
        currentAbortController = new AbortController();

        try {
          const response = await fetch('/api/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              query,
              conversation_id: activeConversationId,
              context_type: currentContextType,
              context_id: currentContextId,
            }),
            signal: currentAbortController.signal
          });

          if (response.ok) {
            const data = await response.json();
            
            // If new conversation was created on the backend
            if (!activeConversationId && data.conversationId) {
              activeConversationId = data.conversationId;
              loadSessions();
            }

            // Append response message
            activeCitations = data.citations || [];
            const modelMsgHtml = `
            <div class="flex items-start max-w-3xl gap-4">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet to-fuchsia-500 text-canvas flex items-center justify-center font-semibold text-[10px] flex-shrink-0 shadow-sm font-mono border border-violet/50">AI</div>
                <div class="py-1 px-1 bg-canvas text-sm text-ink flex-grow">
                  <div class="prose leading-relaxed font-normal whitespace-pre-wrap">${formatResponseWithCitations(data.text)}</div>
                </div>
              </div>
            `;
            
            if (typingIndicator) typingIndicator.classList.add('hidden');
            chatMessages.insertAdjacentHTML('beforeend', modelMsgHtml);
            chatMessages.scrollTop = chatMessages.scrollHeight;

            if (citationCountText) {
              citationCountText.textContent = `${activeCitations.length} Citations Loaded`;
            }

            // Add click listeners to citations [n]
            document.querySelectorAll('.citation-link').forEach(link => {
              link.addEventListener('click', (e) => {
                e.preventDefault();
                const idx = parseInt(e.currentTarget.dataset.index, 10);
                showCitationDetails(idx);
              });
            });
          } else {
            const err = await response.json();
            if (typingIndicator) typingIndicator.classList.add('hidden');
            window.showToast('Error generating answer: ' + err.message, 'error');
          }
        } catch (error) {
          if (error.name === 'AbortError') {
            console.log('Fetch aborted by user');
          } else {
            console.error(error);
            if (typingIndicator) typingIndicator.classList.add('hidden');
            window.showToast('Network error while querying the LLM.', 'error');
          }
        } finally {
          currentAbortController = null;
          
          // Reset button and input state
          chatInput.disabled = false;
          chatInput.focus();
          
          const sendBtn = document.getElementById('sendBtn');
          const sendBtnFill = document.getElementById('sendBtnFill');
          const sendIcon = document.getElementById('sendIcon');
          const loadingIcon = document.getElementById('loadingIcon');
          
          if (sendBtn && sendBtnFill) {
            sendBtn.removeAttribute('disabled');
            sendBtnFill.style.width = '0%';
          }
          if (sendIcon && loadingIcon) {
            sendIcon.classList.remove('hidden');
            loadingIcon.classList.add('hidden');
          }
        }
      });

      chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          chatForm.requestSubmit();
        }
      });

      // Auto grow textarea height
      chatInput.addEventListener('input', () => {
        chatInput.style.height = 'auto';
        chatInput.style.height = Math.min(chatInput.scrollHeight, 120) + 'px';
      });
    }

    // Suggested queries click handlers
    document.querySelectorAll('.suggested-query').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const text = e.currentTarget.textContent.trim().replace(/^"|"$/g, '');
        if (chatInput) {
          chatInput.value = text;
          chatInput.focus();
          chatInput.dispatchEvent(new Event('input'));
        }
      });
    });

    // Initial Load
    loadSessions();
    });
  </script>
</Layout>
